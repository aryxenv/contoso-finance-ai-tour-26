# =============================================================================
# Contoso Finance — Environment Variables
# =============================================================================
# Copy this file to `.env` in the repository root:
#
#   cp .env.example .env
#
# The backend (Pydantic Settings) automatically loads `.env` from the working
# directory. All server variables use the CONTOSO_ prefix.
#
# .env is gitignored — your local settings will never be committed.
# =============================================================================


# -----------------------------------------------------------------------------
# Server — Application
# -----------------------------------------------------------------------------

# Application display name (shown in API docs and health endpoint)
# Default: "Contoso Finance"
# CONTOSO_APP_NAME="Contoso Finance"

# Enable debug mode (additional logging and diagnostics)
# Default: false
# CONTOSO_DEBUG=false


# -----------------------------------------------------------------------------
# Server — Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string (async driver)
# Required: yes — must point to a running PostgreSQL instance
# Default: "postgresql+asyncpg://postgres:postgres@localhost:5432/contoso_finance"
#
# For local development with `npm run dev` (starts Postgres via Docker):
CONTOSO_DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/contoso_finance"
#
# NOTE: Docker Compose overrides this to use the internal service name:
#   postgresql+asyncpg://postgres:postgres@postgres:5432/contoso_finance
# You do NOT need to change this variable when running via Docker Compose.


# -----------------------------------------------------------------------------
# Server — Authentication (JWT)
# -----------------------------------------------------------------------------

# Secret key used to sign and verify JWT tokens
# Required: yes — MUST be changed for production deployments
# Default: "change-me-in-production"
#
# Generate a secure secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#   openssl rand -base64 64
CONTOSO_JWT_SECRET="change-me-in-production"

# JWT signing algorithm
# Default: "HS256"
# CONTOSO_JWT_ALGORITHM="HS256"

# JWT token expiration time in minutes
# Default: 30
# CONTOSO_JWT_EXPIRATION_MINUTES=30


# -----------------------------------------------------------------------------
# Server — CORS
# -----------------------------------------------------------------------------

# Allowed CORS origins (JSON array of strings)
# Default: ["http://localhost:5173"]
#
# For local development, the default allows the Vite dev server.
# For production, set this to your actual frontend domain(s):
#   CONTOSO_CORS_ORIGINS='["https://finance.contoso.com"]'
# CONTOSO_CORS_ORIGINS='["http://localhost:5173"]'


# -----------------------------------------------------------------------------
# Client — Vite (build-time only)
# -----------------------------------------------------------------------------

# Backend API base URL used by the frontend
# Default: "http://localhost:8000"
#
# IMPORTANT: This is a build-time variable. Vite injects it during the build
# step — it cannot be changed at runtime. If you change this value, you must
# rebuild the client.
# VITE_API_URL="http://localhost:8000"


# -----------------------------------------------------------------------------
# Docker — PostgreSQL
# -----------------------------------------------------------------------------
# These variables are used by the `postgres` service in docker-compose.yml.
# They only apply when running PostgreSQL via Docker Compose.

# POSTGRES_DB=contoso_finance
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres


# =============================================================================
# Environment-Specific Notes
# =============================================================================
#
# DEVELOPMENT (default values work out of the box):
#   1. cp .env.example .env
#   2. npm run dev
#   That's it — the defaults are configured for local development.
#
# PRODUCTION — you MUST change these:
#   - CONTOSO_JWT_SECRET    → generate a secure random secret (see above)
#   - CONTOSO_DATABASE_URL  → point to your production PostgreSQL instance
#   - CONTOSO_CORS_ORIGINS  → set to your production frontend domain(s)
#   - CONTOSO_DEBUG          → keep as false (default)
#
# DOCKER COMPOSE:
#   Docker Compose sets its own environment variables for the server container
#   (see docker/docker-compose.yml). Your local .env file is not automatically
#   loaded by Docker Compose. To pass a .env file to Compose, use:
#     docker compose -f docker/docker-compose.yml --env-file .env up --build
# =============================================================================
